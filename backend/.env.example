# =============================================
# NBA 体育信息监控系统 - 环境配置文件
# 复制此文件为 .env 并填入实际配置
# =============================================

# 服务端口（默认 3001）
PORT=3001

# 数据库类型：sqlite 或 mysql
# 本地开发推荐 sqlite，生产部署推荐 mysql
DB_TYPE=sqlite

# ---- MySQL 配置（DB_TYPE=mysql 时生效）----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nba_monitor
DB_USER=nba_user
DB_PASSWORD=your_strong_password
